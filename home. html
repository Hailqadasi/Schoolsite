        // ============================================================
        // 2. قاعدة البيانات (IndexedDB)
        // ============================================================
        function openDB() {
            return new Promise((resolve, reject) => {
                const request = indexedDB.open('MultiBooksDB', 2);
                request.onupgradeneeded = (e) => {
                    const db = e.target.result;
                    if (!db.objectStoreNames.contains('books')) db.createObjectStore('books', { keyPath: 'id' });
                };
                request.onsuccess = (e) => resolve(e.target.result);
                request.onerror = (e) => reject('فشل فتح DB');
            });
        }

        async function getAllBooks() {
            try {
                const db = await openDB();
                const transaction = db.transaction(['books'], 'readonly');
                const store = transaction.objectStore('books');
                return new Promise((resolve, reject) => {
                    const request = store.getAll();
                    request.onsuccess = () => { db.close();
                        allBooksCache = request.result || [];
                        resolve(allBooksCache); };
                    request.onerror = (e) => { db.close();
                        reject(e); };
                });
            } catch (e) { return []; }
        }

        async function addBookToDB(text, name) {
            if (!isAdmin) { alert('⛔ فقط المشرف'); return false; }
            try {
                const db = await openDB();
                const transaction = db.transaction(['books'], 'readwrite');
                const store = transaction.objectStore('books');
                const book = { id: Date.now() + '_' + name, name, text, size: text.length, addedAt: new Date().toISOString() };
                return new Promise((resolve, reject) => {
                    const request = store.add(book);
                    request.onsuccess = () => { db.close(); resolve(true); };
                    request.onerror = (e) => { db.close(); reject(e); };
                });
            } catch (e) { return false; }
        }

        async function deleteBookById(id) {
            if (!isAdmin) { alert('⛔ فقط المشرف'); return false; }
            try {
                const db = await openDB();
                const transaction = db.transaction(['books'], 'readwrite');
                const store = transaction.objectStore('books');
                return new Promise((resolve, reject) => {
                    const request = store.delete(id);
                    request.onsuccess = () => { db.close(); resolve(true); };
                    request.onerror = (e) => { db.close(); reject(e); };
                });
            } catch (e) { return false; }
        }

