                            const db = await openDB();
                            const transaction = db.transaction(['books'], 'readwrite');
                            const store = transaction.objectStore('books');
                            await new Promise((resolve, reject) => {
                                const request = store.add(newBook);
                                request.onsuccess = () => { db.close(); resolve(); };
                                request.onerror = (e) => { db.close(); reject(e); };
                            });
                            success++;
                        } catch (e) {
                            failed++;
                            console.error('فشل استيراد كتاب:', book.name, e);
                        }
                    } else {
                        failed++;
                    }
                }
                
                progressFill.style.width = '100%';
                
                if (success > 0) {
                    statusText.textContent = `✅ تم استيراد ${success} كتاب بنجاح!`;
                    statusDetail.textContent = `📚 ${success} كتاب مستورد من الرابط`;
                    notice.style.borderColor = '#10a37f';
                    notice.style.background = 'rgba(16, 163, 127, 0.2)';
                    
                    await refreshUI();
                } else {
                    statusText.textContent = '⚠️ لم يتم استيراد أي كتاب.';
                    statusDetail.textContent = 'تأكد من أن الملف يحتوي على كتب صالحة.';
                }
                
                if (failed > 0) {
                    statusText.textContent += ` ❌ فشل استيراد ${failed} كتاب.`;
                }
                
            } catch (error) {
                console.error('خطأ في التحميل التلقائي:', error);
                statusText.textContent = '⚠️ ' + error.message;
                statusDetail.textContent = 'يمكنك استخدام زر "تنزيل الكتاب من الرابط" للمحاولة مرة أخرى.';
                progressFill.style.width = '100%';
                notice.style.borderColor = '#ef4444';
                notice.style.background = 'rgba(239, 68, 68, 0.15)';
            }
        }

