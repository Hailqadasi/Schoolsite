        async function searchSelectedBook() {
            const book = getSelectedBook();
            if (!book) { alert('اختر كتاباً أولاً'); return; }
            const word = document.getElementById('searchInput').value.trim();
            if (!word) { alert('✏️ اكتب كلمة للبحث'); return; }
            const container = document.getElementById('resultsContainer');
            const lines = book.text.split(/\r?\n/);
            let html = '',
                count = 0;
            lines.forEach((line, idx) => {
                if (line.toLowerCase().includes(word.toLowerCase())) {
                    count++;
                    const highlighted = line.replace(new RegExp(word, 'gi'), '<mark>$&</mark>');
                    html += `
                            <div class="result-item">
                                <div class="book-source">📌 نتيجة ${count} (سطر ${idx+1})</div>
                                <p>${highlighted}</p>
                                <button style="margin-top:8px; background:#06b6d4; border:none; color:#fff; padding:6px 16px; border-radius:8px; cursor:pointer;" 
                                        onclick="openReader('${book.id}', ${idx})">📖 فتح القارئ</button>
                            </div>
                        `;
                }
            });
            if (count === 0) {
                container.innerHTML = `<div class="no-result">😞 لم نعثر على "${word}" في "${book.name}".</div>`;
            } else {
                container.innerHTML =
                    `<div class="search-result-title">🔍 نتائج البحث عن "${word}" في "${book.name}" (${count})</div>` +
                    html;
            }
        }

