        // ============================================================
        // 5. قارئ النصوص
        // ============================================================
        let currentReaderBookId = null;
        let currentHighlightedLine = -1;
        let readerLines = [];
        let isNightMode = false;
        let currentFontSize = 20;

        function saveReadingProgress(bookId, lineIndex) {
            if (!bookId) return;
            try { localStorage.setItem('reading_progress_' + bookId, String(lineIndex)); } catch (e) {}
        }

        function getReadingProgress(bookId) {
            try { const v = localStorage.getItem('reading_progress_' + bookId); return v ? parseInt(v, 10) : -1; } catch (
            e) { return -1; }
        }

        function openReader(bookId, highlightLine = -1) {
            const book = allBooksCache.find(b => b.id === bookId);
            if (!book) { alert('الكتاب غير موجود'); return; }
            currentReaderBookId = bookId;
            const lines = book.text.split(/\r?\n/);
            readerLines = lines;
            let targetLine = highlightLine;
            if (targetLine < 0 || targetLine >= lines.length) {
                const saved = getReadingProgress(bookId);
                if (saved >= 0 && saved < lines.length) targetLine = saved;
                else targetLine = 0;
            }
            currentHighlightedLine = targetLine;
            document.getElementById('readerBookTitle').textContent = `📖 ${book.name}`;
            const content = document.getElementById('readerContent');
            let html = '';
            lines.forEach((line, idx) => {
                const hl = (idx === targetLine) ? 'highlight' : '';
                const displayLine = line || ' ';
                html +=
                    `<div class="line ${hl}" id="reader-line-${idx}"><span class="line-number">${idx+1}</span> ${displayLine}</div>`;
            });
            content.innerHTML = html;
            const overlay = document.getElementById('readerOverlay');
            overlay.classList.add('active');
            if (isNightMode) overlay.classList.add('night-mode');
            else overlay.classList.remove('night-mode');
            content.style.fontSize = currentFontSize + 'px';
            updateProgress(targetLine, lines.length);
            setTimeout(() => {
                const target = document.getElementById(`reader-line-${targetLine}`);
                if (target) target.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }, 150);
            saveReadingProgress(bookId, targetLine);
            content.onscroll = function() {
                const rect = content.getBoundingClientRect();
                const centerY = rect.top + rect.height / 2;
                let bestLine = 0,
                    bestDist = Infinity;
                const allLines = content.querySelectorAll('.line');
                allLines.forEach((el, idx) => {
                    const r = el.getBoundingClientRect();
                    const mid = r.top + r.height / 2;
                    const d = Math.abs(mid - centerY);
                    if (d < bestDist) { bestDist = d;
                        bestLine = idx; }
                });
                if (bestLine !== currentHighlightedLine && bestLine < lines.length) {
                    currentHighlightedLine = bestLine;
                    allLines.forEach(el => el.classList.remove('highlight'));
                    if (allLines[bestLine]) allLines[bestLine].classList.add('highlight');
                    saveReadingProgress(bookId, bestLine);
                    updateProgress(bestLine, lines.length);
                }
            };
        }

        function updateProgress(currentLine, totalLines) {
            const pct = totalLines > 0 ? Math.round(((currentLine + 1) / totalLines) * 100) : 0;
            document.getElementById('progressFill').style.width = Math.min(pct, 100) + '%';
            document.getElementById('progressText').textContent = Math.min(pct, 100) + '%';
        }

        function closeReader() {
            document.getElementById('readerOverlay').classList.remove('active');
            if (currentReaderBookId && currentHighlightedLine >= 0) {
                saveReadingProgress(currentReaderBookId, currentHighlightedLine);
            }
        }

        function toggleNightMode() {
            const overlay = document.getElementById('readerOverlay');
            isNightMode = !isNightMode;
            overlay.classList.toggle('night-mode', isNightMode);
        }

        function changeFontSize(delta) {
            currentFontSize = Math.min(36, Math.max(14, currentFontSize + delta));
            document.getElementById('readerContent').style.fontSize = currentFontSize + 'px';
        }

