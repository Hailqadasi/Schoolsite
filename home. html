  <!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مكتبتي - استخلاص ذكي</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Cairo', Tahoma, Arial, sans-serif; }
        body { background: linear-gradient(135deg, #0f172a, #2563eb); color: #fff; min-height: 100vh; padding-bottom: 30px; }
        header { padding: 20px; text-align: center; background: rgba(255, 255, 255, .08); backdrop-filter: blur(10px); }
        #title { font-size: 28px; font-weight: bold; }

        #adminBar { background: rgba(0, 0, 0, 0.5); padding: 10px 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; border-bottom: 2px solid rgba(255, 255, 255, 0.1); }
        #adminBar .status { font-size: 16px; font-weight: bold; }
        .role-admin { color: #fbbf24; } .role-guest { color: #94a3b8; }
        .btn-admin { padding: 6px 14px; border: none; border-radius: 8px; cursor: pointer; font-size: 13px; transition: .3s; color: #fff; }
        .btn-login { background: #16a34a; } .btn-logout { background: #ef4444; } .btn-change-pass { background: #f59e0b; }
        .btn-ai-settings { background: #8b5cf6; } .btn-upload-admin { background: #0ea5e9; } .btn-clear-admin { background: #dc2626; }
        .btn-export { background: #8b5cf6; } .btn-import { background: #f59e0b; }
        .btn-admin:hover { transform: scale(1.05); }
        .admin-tools { display: flex; gap: 6px; flex-wrap: wrap; }

        .main-area { padding: 25px 20px 10px; max-width: 800px; margin: 0 auto; }
        .main-area .search-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 15px; }
        .main-area .search-row input[type="text"] { flex: 3; min-width: 200px; padding: 14px 18px; font-size: 18px; border: none; border-radius: 12px; outline: none; }
        .main-area .search-row select { flex: 2; min-width: 160px; padding: 14px 18px; font-size: 18px; border: none; border-radius: 12px; outline: none; background: #fff; color: #1e293b; cursor: pointer; direction: rtl; }
        .main-area .search-row select option { padding: 8px; }

        .action-buttons { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 10px; }
        .action-buttons button { flex: 1; min-width: 90px; padding: 14px 8px; font-size: 16px; font-weight: bold; border: none; border-radius: 14px; cursor: pointer; transition: .3s; color: #fff; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
        .action-buttons button:hover { transform: scale(1.03); }
        .btn-main-search { background: #16a34a; } .btn-main-view { background: #2563eb; }
        .btn-main-search-all { background: #f59e0b; } 
        .btn-main-chatgpt { background: #10a37f; }
        .btn-main-import { background: #f59e0b; }
        .btn-main-download { background: #ef4444; }
        .action-buttons button:disabled { background: #4b5563; cursor: not-allowed; opacity: 0.6; transform: none; }

        #resultsContainer { margin: 25px 20px; max-width: 900px; margin-left: auto; margin-right: auto; }
        .result-item { background: rgba(255, 255, 255, .12); border-radius: 12px; padding: 15px; margin-top: 10px; border-right: 3px solid #60a5fa; }
        .result-item .book-source { font-size: 14px; color: #93c5fd; margin-bottom: 6px; }
        mark { background: yellow; color: #000; padding: 2px 4px; border-radius: 4px; }
        .no-result { background: rgba(255, 0, 0, .2); border: 1px solid #ff6b6b; padding: 15px; border-radius: 12px; }
        .search-result-title { margin: 15px 0 10px 0; font-size: 20px; font-weight: bold; }
        .empty-state { text-align: center; padding: 40px 20px; background: rgba(255, 255, 255, .05); border-radius: 20px; }
        .book-group-title { font-size: 18px; color: #fcd34d; margin-top: 20px; margin-bottom: 10px; border-right: 4px solid #f59e0b; padding-right: 12px; }

        .ai-answer-box { background: rgba(249, 115, 22, 0.15); border: 2px solid #f97316; border-radius: 14px; padding: 20px; margin-bottom: 15px; }
        .ai-answer-box .ai-answer { line-height: 1.9; font-size: 18px; white-space: pre-wrap; }
        .ai-answer-box .ai-model-info { font-size: 13px; color: #94a3b8; margin-top: 10px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.1); }

        .chatgpt-redirect-box { background: rgba(16, 163, 127, 0.15); border: 2px solid #10a37f; border-radius: 14px; padding: 20px; margin-bottom: 15px; text-align: center; }
        .chatgpt-redirect-box .chatgpt-icon { font-size: 48px; margin-bottom: 10px; display: block; }
        .chatgpt-redirect-box .chatgpt-message { font-size: 18px; margin-bottom: 15px; }
        .chatgpt-redirect-box .btn-open-chatgpt { background: #10a37f; border: none; color: #fff; padding: 12px 30px; border-radius: 12px; font-size: 18px; cursor: pointer; font-weight: bold; transition: .3s; }
        .chatgpt-redirect-box .btn-open-chatgpt:hover { transform: scale(1.05); background: #0d8a6a; }

        .share-info-box { background: rgba(139, 92, 246, 0.15); border: 2px solid #8b5cf6; border-radius: 14px; padding: 20px; margin: 15px 0; }
        .share-info-box .share-icon { font-size: 40px; display: block; text-align: center; margin-bottom: 10px; }
        .share-info-box .share-title { font-size: 20px; font-weight: bold; text-align: center; margin-bottom: 10px; color: #c4b5fd; }
        .share-info-box .share-details { font-size: 14px; color: #94a3b8; line-height: 1.8; }

        .import-box { background: rgba(245, 158, 11, 0.15); border: 2px solid #f59e0b; border-radius: 14px; padding: 20px; margin: 15px 0; }
        .import-box .import-icon { font-size: 40px; display: block; text-align: center; margin-bottom: 10px; }
        .import-box .import-title { font-size: 20px; font-weight: bold; text-align: center; margin-bottom: 10px; color: #fbbf24; }
        .import-box .import-details { font-size: 14px; color: #94a3b8; line-height: 1.8; text-align: center; }

        .download-box { background: rgba(239, 68, 68, 0.15); border: 2px solid #ef4444; border-radius: 14px; padding: 20px; margin: 15px 0; }
        .download-box .download-icon { font-size: 40px; display: block; text-align: center; margin-bottom: 10px; }
        .download-box .download-title { font-size: 20px; font-weight: bold; text-align: center; margin-bottom: 10px; color: #fca5a5; }
        .download-box .download-details { font-size: 14px; color: #94a3b8; line-height: 1.8; text-align: center; }
        .download-box .url-input-area { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin: 15px 0; }
        .download-box .url-input-area input { flex: 1; min-width: 200px; padding: 12px; border-radius: 10px; border: none; font-size: 14px; direction: ltr; }
        .download-box .url-input-area button { background: #ef4444; border: none; color: #fff; padding: 12px 25px; border-radius: 10px; cursor: pointer; font-weight: bold; transition: .3s; }
        .download-box .url-input-area button:hover { transform: scale(1.05); background: #dc2626; }
        .download-box .url-input-area button:disabled { background: #4b5563; cursor: not-allowed; opacity: 0.6; }

        .reader-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #f3f4f6; z-index: 3000; display: none; flex-direction: column; direction: rtl; font-family: 'Cairo', 'Tahoma', Arial, sans-serif; }
        .reader-overlay.active { display: flex; }
        .reader-overlay.night-mode { background: #0f172a; color: #e2e8f0; }
        .reader-overlay.night-mode .reader-header { background: #1e293b; border-bottom: 1px solid #334155; }
        .reader-overlay.night-mode .reader-content .line { border-bottom: 1px solid rgba(255,255,255,0.05); }
        .reader-overlay.night-mode .reader-content .line.highlight { background: rgba(251, 191, 36, 0.2); border-right: 4px solid #fbbf24; }
        .reader-overlay.night-mode .reader-content .line-number { color: #64748b; }
        .reader-overlay.night-mode .reader-footer { background: #1e293b; border-top: 1px solid #334155; }

        .reader-header { background: #fff; padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; border-bottom: 2px solid #e5e7eb; flex-shrink: 0; }
        .reader-header .book-title { font-size: 20px; font-weight: bold; color: #1e293b; }
        .reader-overlay.night-mode .reader-header .book-title { color: #fcd34d; }
        .reader-header .reader-controls { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
        .reader-header .reader-controls button { padding: 6px 14px; border: none; border-radius: 8px; cursor: pointer; font-size: 18px; background: #e5e7eb; color: #1e293b; transition: .2s; }
        .reader-overlay.night-mode .reader-header .reader-controls button { background: #334155; color: #f1f5f9; }
        .reader-header .reader-controls button:hover { transform: scale(1.05); }
        .reader-header .reader-controls .btn-close-reader { background: #ef4444; color: #fff; }
        .reader-header .reader-controls .btn-close-reader:hover { background: #dc2626; }

        .reader-content { flex: 1; overflow-y: auto; padding: 25px 40px; line-height: 2.2; font-size: 20px; direction: rtl; text-align: justify; }
        .reader-content .line { padding: 6px 10px; border-radius: 8px; border-right: 3px solid transparent; }
        .reader-content .line.highlight { background: rgba(251, 191, 36, 0.25); border-right: 4px solid #fbbf24; }
        .reader-content .line-number { color: #9ca3af; font-size: 14px; margin-left: 10px; font-weight: bold; }

        .reader-footer { background: #fff; padding: 10px 20px; border-top: 2px solid #e5e7eb; flex-shrink: 0; display: flex; align-items: center; gap: 15px; flex-wrap: wrap; }
        .reader-footer .progress-bar { flex: 1; height: 8px; background: #e5e7eb; border-radius: 10px; overflow: hidden; min-width: 100px; }
        .reader-overlay.night-mode .reader-footer .progress-bar { background: #334155; }
        .reader-footer .progress-bar .progress-fill { height: 100%; width: 0%; background: #2563eb; border-radius: 10px; transition: width 0.3s; }
        .reader-footer .progress-text { font-size: 14px; color: #64748b; min-width: 60px; }
        .reader-overlay.night-mode .reader-footer .progress-text { color: #94a3b8; }
        .reader-footer .font-size-controls { display: flex; gap: 5px; }
        .reader-footer .font-size-controls button { padding: 4px 12px; border: none; border-radius: 6px; cursor: pointer; background: #e5e7eb; font-weight: bold; font-size: 16px; }
        .reader-overlay.night-mode .reader-footer .font-size-controls button { background: #334155; color: #f1f5f9; }

        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 2000; display: none; justify-content: center; align-items: center; }
        .modal-overlay.active { display: flex; }
        .modal-box { background: #1e293b; padding: 30px; border-radius: 20px; max-width: 500px; width: 90%; box-shadow: 0 20px 60px rgba(0,0,0,0.9); }
        .modal-box h3 { margin-bottom: 15px; color: #fcd34d; }
        .modal-box label { display: block; margin-top: 10px; font-size: 14px; color: #94a3b8; }
        .modal-box input, .modal-box select { width: 100%; padding: 12px; border-radius: 10px; border: none; margin-bottom: 5px; font-size: 16px; direction: ltr; }
        .modal-box select { background: #fff; color: #1e293b; cursor: pointer; }
        .modal-box .hint { font-size: 12px; color: #94a3b8; margin-top: 4px; }
        .modal-box .hint a { color: #93c5fd; }
        .modal-box .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 15px; }
        .modal-box .modal-actions button { padding: 10px 20px; border: none; border-radius: 10px; cursor: pointer; font-size: 16px; color: #fff; }
        .modal-box .modal-actions .btn-save { background: #16a34a; }
        .modal-box .modal-actions .btn-cancel { background: #6b7280; }

        .btn-download { background: #10a37f; border: none; color: #fff; padding: 10px 25px; border-radius: 10px; cursor: pointer; font-weight: bold; transition: .3s; }
        .btn-download:hover { transform: scale(1.05); background: #0d8a6a; }
        .btn-copy { background: #8b5cf6; border: none; color: #fff; padding: 10px 25px; border-radius: 10px; cursor: pointer; font-weight: bold; transition: .3s; }
        .btn-copy:hover { transform: scale(1.05); background: #7c3aed; }
        .file-path-box { background: rgba(255,255,255,0.05); padding: 15px; border-radius: 10px; margin-top: 10px; text-align: right; }
        .file-path-box p { color: #94a3b8; font-size: 13px; line-height: 1.8; }
        .file-path-box strong { color: #fbbf24; }

        .progress-bar-custom { width: 100%; height: 6px; background: #334155; border-radius: 10px; overflow: hidden; margin: 10px 0; }
        .progress-bar-custom .progress-fill-custom { height: 100%; width: 0%; background: #10a37f; border-radius: 10px; transition: width 0.3s; }
        .loading-text { color: #94a3b8; font-size: 14px; text-align: center; }

        .auto-download-notice { background: rgba(16, 163, 127, 0.15); border: 2px solid #10a37f; border-radius: 14px; padding: 15px 20px; margin: 15px 0; text-align: center; }
        .auto-download-notice .status-icon { font-size: 32px; display: block; margin-bottom: 8px; }
        .auto-download-notice .status-text { font-size: 16px; color: #e2e8f0; }
        .auto-download-notice .status-detail { font-size: 14px; color: #94a3b8; margin-top: 5px; }
    </style>
</head>
<body>

    <header><div id="title">📚 مكتبتي - استخلاص ذكي</div></header>

    <!-- شريط المشرف -->
    <div id="adminBar">
        <div class="status" id="adminStatus">👤 <span class="role-guest">زائر</span></div>
        <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
            <span id="adminTools" style="display:none; display:flex; gap:6px; flex-wrap:wrap;">
                <button class="btn-admin btn-upload-admin" onclick="document.getElementById('fileInput').click()">📂 رفع</button>
                <input type="file" id="fileInput" class="file-input" accept=".txt,.pdf" style="display:none;" onchange="uploadNewBook(event)" multiple>
                <button class="btn-admin btn-export" onclick="exportBooks()">📤 تصدير</button>
                <button class="btn-admin btn-clear-admin" onclick="deleteAllBooks()">🗑️ حذف الكل</button>
                <button class="btn-admin btn-ai-settings" id="aiSettingsBtn" onclick="showAISettings()">⚙️ AI</button>
            </span>
            <button class="btn-admin btn-login" id="loginBtn" onclick="loginAdmin()">🔑 تسجيل الدخول</button>
            <button class="btn-admin btn-logout" id="logoutBtn" onclick="logoutAdmin()" style="display:none;">🚪 خروج</button>
            <button class="btn-admin btn-change-pass" id="changePassBtn" onclick="showChangePass()" style="display:none;">🔑 تغيير كلمة</button>
        </div>
    </div>

    <!-- المنطقة الرئيسية -->
    <div class="main-area">
        <div class="search-row">
            <input type="text" id="searchInput" placeholder="اكتب سؤالك أو كلمة للبحث...">
            <select id="bookSelector">
                <option value="">-- اختر كتاب --</option>
            </select>
        </div>
        <div class="action-buttons">
            <button class="btn-main-search" id="btnSearch" onclick="searchSelectedBook()">🔍 بحث</button>
            <button class="btn-main-view" id="btnView" onclick="viewSelectedBook()">📖 عرض</button>
            <button class="btn-main-search-all" onclick="searchAllBooks()">🌍 بحث الكل</button>
            <button class="btn-main-chatgpt" onclick="searchInChatGPT()">💬 ChatGPT</button>
            <button class="btn-main-import" onclick="document.getElementById('userImportInput').click()">📥 استيراد</button>
            <button class="btn-main-download" onclick="showDownloadBox()">⬇️ تنزيل الكتاب من الرابط</button>
            <input type="file" id="userImportInput" accept=".json" style="display:none;" onchange="importBooks(event)">
        </div>
    </div>

    <!-- حاوية النتائج -->
    <div id="resultsContainer">
        <div class="empty-state">
            <h3>📖 مرحباً بك</h3>
            <p>ابحث في كتبك، أو ابحث مباشرة في ChatGPT.<br>
            <small style="color:#94a3b8;">📂 يمكنك رفع ملفات .txt و .pdf</small></p>
            <div class="auto-download-notice" id="autoDownloadNotice">
                <span class="status-icon">⏳</span>
                <div class="status-text" id="autoDownloadStatus">جاري تحميل الكتاب من الرابط...</div>
                <div class="status-detail" id="autoDownloadDetail">https://drive.google.com/file/d/1NuAt2ozcu6LZ6G3k0v1iNAI9WvIR3J22/</div>
                <div class="progress-bar-custom" style="margin-top: 10px;">
                    <div class="progress-fill-custom" id="autoProgressFill" style="width: 0%;"></div>
                </div>
            </div>
            <div class="share-info-box" style="margin-top: 20px; text-align: right;">
                <span class="share-icon">📚</span>
                <div class="share-title">مشاركة الكتب مع مستخدمين آخرين</div>
                <div class="share-details">
                    <p>📤 <strong>للمشرف فقط:</strong> اضغط على زر "تصدير" في شريط المشرف لتحميل جميع الكتب كملف JSON.</p>
                    <p>📥 <strong>لجميع المستخدمين:</strong> اضغط على زر "استيراد" واختر ملف JSON، أو استخدم "تنزيل من رابط".</p>
                    <p style="color: #fbbf24; margin-top: 8px;">💡 بهذه الطريقة يمكنك مشاركة مكتبتك مع أي شخص!</p>
                </div>
            </div>
        </div>
    </div>

    <!-- القارئ -->
    <div class="reader-overlay" id="readerOverlay">
        <div class="reader-header">
            <span class="book-title" id="readerBookTitle">📖 عنوان الكتاب</span>
            <div class="reader-controls">
                <button onclick="toggleNightMode()">🌙</button>
                <button class="btn-close-reader" onclick="closeReader()">✕</button>
            </div>
        </div>
        <div class="reader-content" id="readerContent"></div>
        <div class="reader-footer">
            <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
            <span class="progress-text" id="progressText">0%</span>
            <div class="font-size-controls">
                <button onclick="changeFontSize(-2)">أ-</button>
                <button onclick="changeFontSize(2)">أ+</button>
            </div>
        </div>
    </div>

    <!-- نافذة تغيير كلمة المرور -->
    <div class="modal-overlay" id="changePassModal">
        <div class="modal-box">
            <h3>🔑 تغيير كلمة المرور</h3>
            <input type="password" id="currentPassInput" placeholder="الحالية">
            <input type="password" id="newPassInput" placeholder="الجديدة">
            <input type="password" id="confirmPassInput" placeholder="تأكيد الجديدة">
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeChangePass()">إلغاء</button>
                <button class="btn-save" onclick="saveNewPassword()">حفظ</button>
            </div>
        </div>
    </div>

    <!-- نافذة إعدادات الذكاء الاصطناعي -->
    <div class="modal-overlay" id="aiSettingsModal">
        <div class="modal-box">
            <h3>🤖 إعدادات OpenRouter</h3>
            <label>رابط API</label>
            <input type="text" id="aiApiUrl" placeholder="https://openrouter.ai/api/v1/chat/completions" value="https://openrouter.ai/api/v1/chat/completions">
            <label>مفتاح API</label>
            <input type="password" id="aiApiKey" placeholder="مفتاح OpenRouter...">
            <label>النموذج</label>
            <select id="aiModel">
                <option value="google/gemini-2.0-flash-exp:free">Gemini 2.0 Flash (مجاني)</option>
                <option value="google/gemini-2.0-pro-exp-02-05:free">Gemini 2.0 Pro (مجاني)</option>
                <option value="meta-llama/llama-3.1-8b-instruct:free">Llama 3.1 8B (مجاني)</option>
                <option value="mistralai/mistral-7b-instruct:free">Mistral 7B (مجاني)</option>
                <option value="deepseek/deepseek-chat:free">DeepSeek Chat (مجاني)</option>
                <option value="openai/gpt-3.5-turbo">GPT-3.5 Turbo</option>
                <option value="openai/gpt-4-turbo">GPT-4 Turbo</option>
                <option value="anthropic/claude-3.5-sonnet">Claude 3.5 Sonnet</option>
            </select>
            <div class="hint">💡 احصل على مفتاح مجاني: <a href="https://openrouter.ai/keys" target="_blank">OpenRouter Keys</a></div>
            <div class="hint">⚠️ النماذج المجانية محدودة بعدد الطلبات في اليوم</div>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeAISettings()">إلغاء</button>
                <button class="btn-save" onclick="saveAISettings()">حفظ</button>
            </div>
        </div>
    </div>

    <script>
        // ============================================================
        // 1. الصلاحيات + إعدادات AI (نفس الكود السابق)
        // ============================================================
        let allBooksCache = [];
        let isAdmin = false;
        const ADMIN_PASS_KEY = 'admin_password';
        const DEFAULT_PASS = 'admin123';
        const AI_CONFIG_KEY = 'ai_config';

        if (!localStorage.getItem(ADMIN_PASS_KEY)) localStorage.setItem(ADMIN_PASS_KEY, DEFAULT_PASS);

        function getAIConfig() {
            try { const raw = localStorage.getItem(AI_CONFIG_KEY); if (raw) return JSON.parse(raw); } catch (e) {}
            return { 
                apiUrl: 'https://openrouter.ai/api/v1/chat/completions', 
                apiKey: '', 
                model: 'google/gemini-2.0-flash-exp:free' 
            };
        }

        function showAISettings() {
            if (!isAdmin) { alert('⛔ فقط المشرف'); return; }
            const config = getAIConfig();
            document.getElementById('aiApiUrl').value = config.apiUrl || 'https://openrouter.ai/api/v1/chat/completions';
            document.getElementById('aiApiKey').value = config.apiKey || '';
            document.getElementById('aiModel').value = config.model || 'google/gemini-2.0-flash-exp:free';
            document.getElementById('aiSettingsModal').classList.add('active');
        }
        function closeAISettings() { document.getElementById('aiSettingsModal').classList.remove('active'); }
        function saveAISettings() {
            const config = {
                apiUrl: document.getElementById('aiApiUrl').value.trim(),
                apiKey: document.getElementById('aiApiKey').value.trim(),
                model: document.getElementById('aiModel').value.trim()
            };
            if (!config.apiUrl || !config.apiKey || !config.model) { alert('❌ املأ جميع الحقول'); return; }
            localStorage.setItem(AI_CONFIG_KEY, JSON.stringify(config));
